{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/ml/(.*)",
      "dest": "/ml/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://your-backend-url.vercel.app/api",
    "REACT_APP_ML_URL": "https://your-ml-url.vercel.app/ml"
  }
}